<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>com.eoiagent</groupId>
    <artifactId>eoiagent-parent</artifactId>
    <version>0.1.0</version>
  </parent>
  <artifactId>eoiagent-runtime</artifactId>
  <name>eoiagent-runtime</name>
  <description>
    Agent runtime / orchestration (T-111). Phase 1: ReActOrchestrator (our bounded reason+act loop,
    Flow B, read-only) and AgenticOrchestrator (langchain4j-agentic, experimental — quarantined to
    this adapter module per ADR-0010). Planner/TaskManager and Flows C/D/E arrive in Phase 2/3.
  </description>

  <properties>
    <!-- ADR-0014: stable JPMS automatic module name (T-404). -->
    <automatic.module.name>com.eoiagent.runtime</automatic.module.name>
  </properties>

  <dependencies>
    <dependency>
      <groupId>com.eoiagent</groupId>
      <artifactId>eoiagent-core</artifactId>
    </dependency>

    <!-- ChatModel + AI-Service annotations (@UserMessage/@V) used by the agentic adapter. -->
    <dependency>
      <groupId>dev.langchain4j</groupId>
      <artifactId>langchain4j</artifactId>
    </dependency>
    <!-- EXPERIMENTAL (ADR-0010): the agentic workflow engine lives ONLY in this adapter module.
         Version comes from langchain4j-bom (1.16.3-beta26) — never hardcoded here. -->
    <dependency>
      <groupId>dev.langchain4j</groupId>
      <artifactId>langchain4j-agentic</artifactId>
    </dependency>
    <!-- EXPERIMENTAL / single-maintainer (ADR-0005, ADR-0010): the LangGraph4j stateful-graph engine
         lives ONLY in this adapter module (LangGraphOrchestrator, Flow E). Version from eoiagent-bom. -->
    <dependency>
      <groupId>org.bsc.langgraph4j</groupId>
      <artifactId>langgraph4j-core</artifactId>
    </dependency>

    <!-- Test-only concrete adapters to wire the loop end-to-end, offline. -->
    <dependency>
      <groupId>com.eoiagent</groupId>
      <artifactId>eoiagent-tool</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>com.eoiagent</groupId>
      <artifactId>eoiagent-scratchpad</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>
</project>
